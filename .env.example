# Copy to .env for local development (values match docker-compose.yml).
# Leave DATABASE_URL unset to use the in-memory user store instead of Postgres.
DATABASE_URL="postgresql://aster:aster_dev_password@localhost:5432/aster_horoscope?schema=public"

# YouTube Data API v3 key (Google Cloud Console -> enable "YouTube Data API v3" -> Credentials).
# Optional: without it, Aster School video lessons still work but skip live view counts.
YOUTUBE_API_KEY=
